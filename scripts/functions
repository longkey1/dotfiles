#!/usr/bin/env bash

function symlink() {
  local target=${1}
  local link_name=${2:-${1}}
  local link_path="${HOME}/.${link_name}"

  if [ -e "${link_path}" ]; then
    echo "${link_path} already exists"
  else
    ln -s "${ROOT}"/"${target}" "${link_path}" && echo "${link_path} linked"
  fi
}

function unsymlink() {
  local target=${1}
  local link_name
  link_name=$(basename "${target}")
  local link_path="${REMOTE_BIN}/${link_name}"

  if [ -h "${link_path}" ]; then
    unlink "${link_path}" && echo "${link_path} unlinked"
  elif [ -e "${link_path}" ]; then
    echo "${link_path} not unlinked, not a symlink"
  else
    echo "${link_path} no exists"
  fi
}

function npm_install_global() {
  local label=${1}
  local package=${2}
  local version=${3:-latest}

  local before
  before=$(npm list --global --prefix "${ROOT}/local" "${package}" --json 2> /dev/null | "${LOCAL_BIN}/jq" -r ".dependencies[\"${package}\"].version // \"\"")
  npm install --global --prefix "${ROOT}/local" --no-package-lock --no-fund --silent "${package}@${version}"
  local after
  after=$(npm list --global --prefix "${ROOT}/local" "${package}" --json 2> /dev/null | "${LOCAL_BIN}/jq" -r ".dependencies[\"${package}\"].version // \"\"")

  if [ -z "${after}" ]; then
    echo "${label}: failed to install ${package}"
  elif [ -z "${before}" ]; then
    echo "${label}: installed ${package}@${after}"
  elif [ "${before}" = "${after}" ]; then
    echo "${label}: ${package}@${after} is already up to date"
  else
    echo "${label}: upgraded ${package} from ${before} to ${after}"
  fi
}

function get_bitwarden_session() {
  cat "${SCRIPTS}/bitwarden.session"
}

function execute_envsubst() {
  OPTION=${1}
  DESTINATION=${2}
  SOURCE=${3}
  echo "envsubst "'${OPTION}'" < ${DESTINATION} > ${SOURCE}"
  envsubst "'${OPTION}'" < "${DESTINATION}" > "${SOURCE}"
}

function symlink_to_symlink() {
  local target=${1}
  local source_path="${ROOT}/${target}"
  local dest_path
  dest_path="${REMOTE_BIN}/$(basename "${target}")"

  if [ -h "${dest_path}" ] && [ ! -e "${dest_path}" ]; then
    echo "${dest_path} is broken, re-linking"
    unlink "${dest_path}"
  elif [ -e "${dest_path}" ]; then
    echo "${dest_path} already exists"
    return
  fi

  # Check if source is a symlink
  if [ ! -h "${source_path}" ]; then
    echo "${source_path} is not a symlink"
    return
  fi

  # Get the absolute path of the link target
  local link_target
  link_target=$(readlink "${source_path}")
  local source_dir
  source_dir=$(dirname "${source_path}")
  local absolute_link_target="${source_dir}/${link_target}"
  local normalized_link_target
  normalized_link_target=$(realpath "${absolute_link_target}")

  # Create symlink with normalized absolute path
  ln -s "${normalized_link_target}" "${dest_path}" && echo "${dest_path} linked"
}
